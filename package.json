{
  "name": "manifold-server",
  "version": "1.1.0",
  "description": "High-performance Bonk.io RL environment with ZeroMQ IPC bridge",
  "main": "index.js",
  "scripts": {
    "test": "npx tsx tests/runner.ts all",
    "test:runner": "npx tsx tests/runner.ts",
    "test:list": "npx tsx tests/runner.ts list",
    "test:physics": "npx tsx tests/runner.ts 1",
    "test:prng": "npx tsx tests/runner.ts 2",
    "test:env": "npx tsx tests/runner.ts 3",
    "test:frameskip": "npx tsx tests/runner.ts 4",
    "test:shared": "npx tsx tests/runner.ts 5",
    "test:shutdown": "npx tsx tests/runner.ts 6",
    "test:telemetry": "npx tsx tests/runner.ts 7",
    "test:manager": "npx tsx tests/runner.ts 8",
    "test:telemetry:legacy": "npx tsx tests/telemetry.ts",
    "test:map-types": "npx tsx tests/runner.ts 9",
    "test:collision": "npx tsx tests/runner.ts 10",
    "test:nophysics": "npx tsx tests/runner.ts 11",
    "test:grapple": "npx tsx tests/runner.ts 12",
    "test:bounds": "npx tsx tests/runner.ts 13",
    "test:integration": "npx tsx tests/runner.ts 14",
    "bench:throughput": "python python/benchmarks/throughput_benchmark.py",
    "bench:native": "npx tsx benchmarks/quick-2000-step.ts",
    "bench:pool": "npx tsx benchmarks/step-throughput.ts",
    "bench:diagnose": "npx tsx benchmarks/diagnose-ipc.ts",
    "bench:telemetry": "npx tsx benchmarks/telemetry.ts",
    "bench:all": "npx tsx benchmarks/quick-2000-step.ts && npx tsx benchmarks/step-throughput.ts && npx tsx benchmarks/telemetry.ts",
    "start": "tsx src/main.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "bonk",
    "reinforcement-learning",
    "rl",
    "game-simulation"
  ],
  "author": "SneezingCactus",
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "box2d": "^1.0.0",
    "chalk": "^5.3.0",
    "columnify": "^1.6.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "moment": "^2.30.1",
    "socket.io": "^4.7.4",
    "word-wrap": "^1.2.5",
    "zeromq": "^6.5.0"
  },
  "devDependencies": {
    "@types/columnify": "^1.5.4",
    "@types/express": "^4.17.21",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
