{
  "name": "manifold-server",
  "version": "1.1.0",
  "description": "High-performance Bonk.io RL environment with ZeroMQ IPC bridge",
  "main": "src/main.ts",
  "scripts": {
    "test": "npx tsx tests/runner.ts all",
    "test:runner": "npx tsx tests/runner.ts",
    "test:list": "npx tsx tests/runner.ts list",
    "test:physics": "npx tsx tests/runner.ts 1",
    "test:prng": "npx tsx tests/runner.ts 2",
    "test:env": "npx tsx tests/runner.ts 3",
    "test:frameskip": "npx tsx tests/runner.ts 4",
    "test:shared": "npx tsx tests/runner.ts 5",
    "test:manager": "npx tsx tests/runner.ts 6",
    "test:map-types": "npx tsx tests/runner.ts 7",
    "test:collision": "npx tsx tests/runner.ts 8",
    "test:nophysics": "npx tsx tests/runner.ts 9",
    "test:grapple": "npx tsx tests/runner.ts 10",
    "test:bounds": "npx tsx tests/runner.ts 11",
    "test:integration": "npx tsx tests/runner.ts 12",
    "bench:all": "npx tsx benchmarks/runner.ts all",
    "bench:runner": "npx tsx benchmarks/runner.ts",
    "bench:list": "npx tsx benchmarks/runner.ts --list",
    "bench:layer1": "npx tsx benchmarks/layer1-primitives.ts",
    "bench:layer2": "npx tsx benchmarks/layer2-physics.ts",
    "bench:layer3": "npx tsx benchmarks/layer3-environment.ts",
    "bench:layer4": "npx tsx benchmarks/layer4-worker-pool.ts",
    "bench:layer5": "npx tsx benchmarks/layer5-memory.ts",
    "bench:layer6": "npx tsx benchmarks/layer6-stability.ts",
    "bench:layer7": "python python/benchmarks/layer7-ipc-throughput.py",
    "bench:ipc-profile": "python python/benchmarks/layer7-ipc-latency.py",
    "bench:ipc-stress": "python python/benchmarks/layer7-ipc-stress.py",
    "start": "tsx src/main.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "bonk",
    "reinforcement-learning",
    "rl",
    "game-simulation"
  ],
  "author": "SneezingCactus",
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "box2d": "^1.0.0",
    "zeromq": "^6.5.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
